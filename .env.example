# Database — local: MongoDB | Azure: Cosmos DB (MongoDB API)
MONGODB_URI=mongodb://localhost:27017/fraud_detection
MONGODB_DB_NAME=fraud_detection

# RAG — local: Chroma | Azure: AI Search
CHROMA_PERSIST_DIR=./data/chroma
AZURE_SEARCH_ENDPOINT=https://<search>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=fraud-policies

# LLM — local Ollama (default) or Azure OpenAI (cloud)
LLM_MOCK=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# Azure OpenAI (set LLM_PROVIDER=azure when using cloud)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Web search (External Threat Intel)
TAVILY_API_KEY=
WEB_SEARCH_MOCK=true
WEB_SEARCH_ALLOWED_DOMAINS=reuters.com,bleepingcomputer.com,krebsonsecurity.com

# App
LOG_LEVEL=INFO
HITL_CONFIDENCE_THRESHOLD=0.5
SEED_ON_STARTUP=false
INDEX_ON_STARTUP=false
CORS_ORIGINS=http://localhost:5173

# Azure observability (prod)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Frontend (build-time, web/.env)
# VITE_API_URL=http://localhost:8000
